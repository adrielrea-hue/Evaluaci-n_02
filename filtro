import numpy as np
import matplotlib.pyplot as plt
from scipy.io import wavfile
from scipy.signal import get_window
from scipy.fft import rfft, rfftfreq, irfft

FS, audio = wavfile.read('lung-sound.wav')

if len(audio.shape) > 1:
    audio = audio[:, 0]

audio = audio.astype(float)
audio = audio / np.max(np.abs(audio))

threshold = 0.02
indices = np.where(np.abs(audio) > threshold)[0]

start = indices[0]

N = 4096
segment = audio[start:start+N]

if len(segment) < N:
    segment = np.pad(segment, (0, N - len(segment)))

window = get_window('hann', N)
windowed = segment * window

yf = rfft(windowed)
xf = rfftfreq(N, 1/FS)

mag = np.abs(yf)

peak_freq = 212

bandwidth = 20  # ancho de banda pequeño
mask = (xf > peak_freq - bandwidth) & (xf < peak_freq + bandwidth)

yf_solo = np.zeros_like(yf)
yf_solo[mask] = yf[mask]

signal_solo = irfft(yf_solo)

yf_clean = yf.copy()
yf_clean[mask] = 0

signal_clean = irfft(yf_clean)
plt.figure(figsize=(12,8))

plt.subplot(3,1,1)
plt.plot(segment)
plt.title("Señal original")

plt.subplot(3,1,2)
plt.plot(signal_solo)
plt.title("Componente aislada (~212 Hz)")

plt.subplot(3,1,3)
plt.plot(signal_clean)
plt.title("Señal sin la componente de 212 Hz")

plt.tight_layout()
plt.show()
